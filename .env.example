# ================================================================
# Ahri V3 - Environment Configuration
# ================================================================
# 1. Copy this file to .env (in the repo root) before starting the backend.
# 2. Fill in the values you need. Most keys are optional and only required
#    if you enable the corresponding feature (Spotify, Google Search, etc.).
# 3. AUTH_PASSWORD and JWT_SECRET are REQUIRED for the backend to start.
# 4. Never commit a populated .env. See README.md ("Environment Variables")
#    for grouping and security notes.
# ================================================================

# === LLM Providers ===
# Gemini (Google AI Studio). At least one key is required for the chat
# pipeline. The "paid" key is used first; the "free" key is a fallback.
GEMINI_API_KEY_PAID=
GEMINI_API_KEY_FREE=

# OpenRouter — gives access to DeepSeek, Mistral, etc. Optional.
OPENROUTER_API_KEY=
OPENROUTER_MODEL_NAME=deepseek/deepseek-r1:free

# === Google Custom Search ===
# Optional. Used by the web-search worker / tool. Both keys are rotated.
CSE_API_KEY=
CSE_CX=
GOOGLE_API_KEY_SEARCH=
GOOGLE_API_KEY_SEARCH_B=

# === Google Vision ===
# Optional. Used for the multimodal vision pipeline. Both keys are rotated.
GOOGLE_API_KEY_VISION_A=
GOOGLE_API_KEY_VISION_B=

# === Memory Manager ===
# Optional. Dedicated Gemini key for the memory-analyzer pipeline so its
# token budget does not compete with chat traffic.
GOOGLE_API_KEY_MANAGER=

# === Spotify ===
# Optional. Required for the Spotify-aware persona daemon.
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://localhost:8888/callback

# === Auth ===
# REQUIRED. Set a non-trivial password and a long random JWT secret before
# starting the backend. Do not ship default values.
AUTH_PASSWORD=
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Backend ===
BACKEND_PORT=8742
DATABASE_URL=sqlite+aiosqlite:///data/db/ahri.db
CHROMA_PATH=data/vector_db

# === Mobile Access (Cloudflare Tunnel) ===
# Optional. Used by helper scripts to publish the tunnel URL via a private
# GitHub gist so the mobile PWA can reach the backend.
GH_TOKEN=
GIST_ID=
