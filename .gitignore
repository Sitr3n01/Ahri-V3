# ================================================================
# Ahri V3 - Monorepo .gitignore
# ================================================================

# === Environment ===
.env
.env.local
.env.*.local

# === Node.js ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.turbo/

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
*.pyc

# === Build Outputs ===
dist/
dist-electron/
build/
*.tsbuildinfo

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === OS Files ===
.DS_Store
Thumbs.db
desktop.ini

# === Data (managed separately, not in git) ===
data/db/*.db
data/db/*.db-journal
data/vector_db/
data/assets/
packages/backend/ahri.db
packages/backend/=1.0.0
packages/backend/data/
*.lock

# === Electron ===
release/

# === Logs ===
*.log
logs/
cloudflare.log

# === Spotify Cache ===
.spotify_cache
.cache-*

# === Misc ===
*.bak
*.tmp
coverage/
coverage-final/
.nyc_output/
.vitest-cache/
*.coverage

# === Local AI tool memory ===
memory/

# === Local databases at any path ===
*.sqlite
*.sqlite3
*.db
*.db-journal

# === Persona runtime data (chat history, per-user memory, RAG trackers) ===
# Seed content (persona.md, lore.md, knowledge/*.md) stays tracked.
data/personas/*/history/
data/personas/*/memory.json
data/personas/*/rag_tracker.json
packages/backend/data/personas/*/history/
packages/backend/data/personas/*/memory.json
packages/backend/data/personas/*/rag_tracker.json

# === Local AI/development artifacts (not in git) ===
AGENTS.md
CLAUDE.md
GEMINI.md
.agent/
.agents/
.claude/
.codex/
.cursor/
.continue/
.aider*
.github/prompts/
.github/workflows/claude-quality-assistant.yml
.github/workflows/codex-quality-explainer.yml
docs/development/
reports/
!reports/.gitkeep
.quality-gate/
dev_log.txt
packages/desktop/test-req.mjs
*.scratch.md
