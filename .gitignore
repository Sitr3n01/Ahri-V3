# ================================================================
# Ahri V3 - Monorepo .gitignore
# ================================================================

# === Environment ===
.env
.env.local
.env.*.local

# === Node.js ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.turbo/

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
*.pyc

# === Build Outputs ===
dist/
dist-electron/
build/
*.tsbuildinfo

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === OS Files ===
.DS_Store
Thumbs.db
desktop.ini

# === Data (managed separately, not in git) ===
data/db/*.db
data/db/*.db-journal
data/vector_db/
data/assets/
*.lock

# === Electron ===
release/

# === Logs ===
*.log
logs/
cloudflare.log

# === Spotify Cache ===
.spotify_cache
.cache-*

# === Misc ===
*.bak
*.tmp
coverage/
.nyc_output/
